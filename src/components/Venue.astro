---
import workshop from "../data/workshop.json";
---

<section id="venue" class="px-6 py-12 max-w-3xl mx-auto">
  <!-- Section divider -->
  <div class="reveal flex items-center gap-4 mb-10">
    <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
    <div class="w-1.5 h-1.5 rotate-45 border border-[#c0533d]/40"></div>
    <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
  </div>

  <div class="reveal mb-8">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#c0533d] mb-3">Getting There</p>
    <h2 class="font-[family-name:var(--font-fraunces)] text-3xl md:text-4xl text-[#1a1a2e] font-light">Venue</h2>
  </div>

  <div class="reveal reveal-delay-1 bg-white p-8 md:p-10 border border-[#1a1a2e]/6 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
    <div class="grid sm:grid-cols-2 gap-8">
      <div>
        <h3 class="font-[family-name:var(--font-fraunces)] text-xl text-[#1a1a2e] font-normal mb-3">Imperial College London</h3>
        <p class="font-[family-name:var(--font-source-serif)] text-[15px] text-[#1a1a2e]/50 leading-relaxed mb-4">
          Department of Computing<br />
          South Kensington Campus<br />
          London SW7 2AZ
        </p>
        <p class="font-[family-name:var(--font-source-serif)] text-sm text-[#1a1a2e]/35 italic">
          Exact room to be confirmed.
        </p>
      </div>
      <div class="flex flex-col gap-4">
        <div>
          <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.25em] uppercase text-[#1a1a2e]/30 mb-1.5">Nearest Tube</p>
          <p class="font-[family-name:var(--font-source-serif)] text-[15px] text-[#1a1a2e]/60">South Kensington &middot; Gloucester Road</p>
        </div>
        <div>
          <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.25em] uppercase text-[#1a1a2e]/30 mb-1.5">Contact</p>
          <p id="contact-email" class="font-[family-name:var(--font-source-serif)] text-[15px] text-[#1e3a5f]">
            <span class="select-none" aria-hidden="true">doc-spike</span><!--
            --><span class="hidden">REMOVE</span><!--
            --><span class="select-none" aria-hidden="true">&#64;</span><!--
            --><span class="select-none" aria-hidden="true">imperial.ac.uk</span>
          </p>
          <script>
            {const el=document.getElementById('contact-email');if(el){const a=document.createElement('a');const u=['doc-spike','imperial.ac.uk'].join('@');a.href='mai'+'lto:'+u;a.textContent=u;a.className='hover:underline decoration-[#c0533d]/30 underline-offset-2 hover:decoration-[#c0533d] transition-colors duration-200';el.replaceChildren(a);}}
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

{/* Registration CTA */}
<section id="register" class="px-6 py-12 max-w-3xl mx-auto">
  <div class="reveal text-center py-16 border-y border-[#1a1a2e]/8">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#c0533d] mb-4">Join Us</p>
    <h2 class="font-[family-name:var(--font-fraunces)] text-3xl md:text-4xl text-[#1a1a2e] font-light mb-4 italic" style="font-variation-settings: 'SOFT' 100, 'WONK' 1;">
      Registration
    </h2>
    <p class="font-[family-name:var(--font-source-serif)] text-base text-[#1a1a2e]/50 max-w-md mx-auto mb-8 leading-relaxed">
      The workshop is open to members of the SPIKE research group and invited collaborators. Afternoon breakout sessions are designed for in-person collaboration, so we encourage you to attend in person if possible. To register your interest, please get in touch.
    </p>
    <a
      href="https://forms.office.com/e/hYZRMZbUy0"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block font-[family-name:var(--font-jetbrains)] text-[11px] tracking-[0.2em] uppercase px-8 py-3.5 bg-[#1e3a5f] text-[#f7f3ec] hover:bg-[#162d4a] transition-colors duration-200"
    >
      Register Interest
    </a>
  </div>
</section>

{/* Sponsors */}
<section class="px-6 py-12 max-w-3xl mx-auto">
  <div class="reveal text-center">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#1a1a2e]/30 mb-6">With grateful thanks to our sponsor</p>
    <img src="/city-logo.svg" alt="City St George's, University of London" class="h-11 opacity-40 mx-auto" />
  </div>
</section>

<footer class="px-6 pt-12 pb-16 max-w-3xl mx-auto">
  <div class="reveal flex flex-col items-center gap-6">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#1a1a2e]/25 mb-0">Organised by</p>
    <div class="flex flex-wrap items-center justify-center gap-6">
      <img src="/spike-logo.svg" alt="SPIKE" class="h-7 opacity-40" />
      <div class="w-px h-6 bg-[#1a1a2e]/10"></div>
      <img src="/imperial-logo.svg" alt="Imperial College London" class="h-5 opacity-30" />
    </div>
    <p class="font-[family-name:var(--font-source-serif)] text-xs text-[#1a1a2e]/25">
      SPIKE Research Group &middot; Department of Computing &middot; Imperial College London &copy; 2026
    </p>
  </div>
</footer>
