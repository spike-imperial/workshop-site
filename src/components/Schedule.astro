---
import workshop from "../data/workshop.json";

const typeLabels: Record<string, string> = {
  break: "Break",
  talk: "Talk",
  session: "Session",
};

const typeColors: Record<string, { bar: string; text: string; bg: string }> = {
  talk:    { bar: "bg-[#c0533d]",  text: "text-[#c0533d]",  bg: "bg-[#c0533d]/8" },
  session: { bar: "bg-[#1e3a5f]",  text: "text-[#1e3a5f]",  bg: "bg-[#1e3a5f]/8" },
  break:   { bar: "bg-[#b8a88a]",  text: "text-[#b8a88a]",  bg: "bg-[#b8a88a]/10" },
};

function slugify(name: string): string {
  return "speaker-" + name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
}

// Build a set of speaker names that have entries in the speakers section
const speakerSlugs = new Map(
  (workshop.speakers || []).map((s: { name: string }) => [s.name, slugify(s.name)])
);

// Filter out items with visible: false
const visibleSchedule = workshop.schedule.filter((item) => item.visible !== false);

// Split schedule into morning and afternoon
const morningEnd = visibleSchedule.findIndex((item) => item.title === "Lunch");
const morning = visibleSchedule.slice(0, morningEnd);
const afternoon = visibleSchedule.slice(morningEnd);

function hasDetails(item: typeof workshop.schedule[number]) {
  return item.abstract || item.slides || item.recording;
}
---

<section id="schedule" class="px-6 py-12 max-w-3xl mx-auto">
  <div class="reveal mb-10 relative z-10">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#c0533d] mb-3">Programme</p>
    <h2 class="font-[family-name:var(--font-fraunces)] text-3xl md:text-4xl text-[#1a1a2e] font-light">Schedule</h2>
    <p class="font-[family-name:var(--font-source-serif)] text-sm text-[#1a1a2e]/40 mt-3 italic">
      Morning lightning talks, afternoon breakout sessions
    </p>

    {/* Legend + Calendar */}
    <div class="flex items-center justify-between mt-5">
      <div class="flex items-center gap-5">
        {Object.entries(typeLabels).map(([key, label]) => (
          <div class="flex items-center gap-2">
            <span class={`block w-2.5 h-2.5 rounded-[2px] ${typeColors[key].bar}`}></span>
            <span class={`font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.15em] uppercase ${typeColors[key].text}`}>
              {label}
            </span>
          </div>
        ))}
      </div>

      <div class="relative z-30" id="cal-btn-wrapper">
      <button
        id="cal-btn"
        class="flex items-center gap-2 font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.18em] uppercase text-[#1e3a5f]/50 hover:text-[#1e3a5f] border border-[#1a1a2e]/12 hover:border-[#1a1a2e]/25 rounded-sm px-3 py-2 transition-colors duration-200"
        aria-expanded="false"
        aria-haspopup="true"
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="1" y="2" width="10" height="9" rx="1"/><path d="M1 5h10M4 1v2M8 1v2"/>
        </svg>
        Add to Calendar
        <span id="cal-chevron" class="text-[8px] transition-transform duration-200">&#9662;</span>
      </button>

      <div
        id="cal-dropdown"
        class="hidden absolute right-0 top-full mt-1.5 z-20 bg-[#f7f3ec] border border-[#1a1a2e]/10 rounded-sm shadow-[0_4px_12px_rgba(0,0,0,0.1)] min-w-[210px]"
        role="menu"
      >
        <a
          href="/calendar.ics"
          download="nsai-workshop-2026.ics"
          class="flex items-center gap-3 px-4 py-3 font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.15em] uppercase text-[#1a1a2e]/50 hover:text-[#1e3a5f] hover:bg-[#1e3a5f]/[0.04] transition-colors duration-150 border-b border-[#1a1a2e]/6"
          role="menuitem"
        >
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 1v6M2 5l3 3 3-3M1 9h8"/>
          </svg>
          Download .ics file
        </a>
        <button
          id="cal-copy-btn"
          class="w-full flex items-center gap-3 px-4 py-3 font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.15em] uppercase text-[#1a1a2e]/50 hover:text-[#1e3a5f] hover:bg-[#1e3a5f]/[0.04] transition-colors duration-150 text-left"
          role="menuitem"
        >
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M6.5 3.5a2.5 2.5 0 0 1 0 3.5l-.5.5a2.5 2.5 0 0 1-3.5-3.5l.5-.5"/><path d="M3.5 6.5a2.5 2.5 0 0 1 0-3.5l.5-.5a2.5 2.5 0 0 1 3.5 3.5l-.5.5"/>
          </svg>
          <span id="cal-copy-label">Copy subscribe link</span>
        </button>
      </div>
    </div>
    </div>
  </div>

  {/* Morning block */}
  <div class="reveal reveal-delay-1 mb-10">
    <div class="flex items-center gap-4 mb-5">
      <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.25em] uppercase text-[#1e3a5f]/50 whitespace-nowrap">Morning</p>
      <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
    </div>

    <div class="space-y-0">
      {morning.map((item, i) => {
        const colors = typeColors[item.type] || typeColors.break;
        const expandable = hasDetails(item);
        return (
          <div class="schedule-row" data-expandable={expandable ? "true" : undefined}>
            <div class={`flex items-stretch border-b border-[#1a1a2e]/6 transition-colors duration-200 hover:bg-[#1e3a5f]/[0.025] ${expandable ? 'cursor-pointer' : ''} ${i % 2 === 0 ? 'bg-[#1a1a2e]/[0.012]' : ''}`}>
              {/* Colored vertical bar */}
              <div class={`w-[3px] flex-shrink-0 rounded-full my-2 ${colors.bar} ${item.type === 'break' ? 'opacity-40' : 'opacity-80'}`}></div>

              <div class="flex-1 flex items-baseline py-3.5 pl-4 pr-2 gap-4 min-w-0">
                {/* Time */}
                <span class={`font-[family-name:var(--font-jetbrains)] text-[13px] tabular-nums flex-shrink-0 w-12 ${item.type === 'break' ? 'text-[#1a1a2e]/30' : 'text-[#1a1a2e]/45'}`}>
                  {item.time}
                </span>

                {/* Title */}
                <span class={`font-[family-name:var(--font-source-serif)] text-[15px] flex-1 min-w-0 ${item.type === 'break' ? 'text-[#1a1a2e]/35 italic' : 'text-[#1a1a2e]'}`}>
                  {item.title}
                </span>

                {/* Speaker (mobile: below title, desktop: inline) */}
                {item.speaker && (
                  <span class={`font-[family-name:var(--font-source-serif)] text-[13px] flex-shrink-0 hidden sm:inline ${item.speaker === 'TBC' ? 'italic text-[#1a1a2e]/25' : 'text-[#1a1a2e]/45'}`}>
                    {item.speaker !== 'TBC' && speakerSlugs.has(item.speaker) ? (
                      <a href={`#${speakerSlugs.get(item.speaker)}`} class="underline decoration-[#c0533d]/25 underline-offset-2 hover:decoration-[#c0533d] transition-colors duration-200" onclick="event.stopPropagation()">
                        {item.speaker}
                      </a>
                    ) : (
                      item.speaker
                    )}
                  </span>
                )}

                {/* Expand chevron for items with details */}
                {expandable && (
                  <span class="schedule-chevron font-[family-name:var(--font-jetbrains)] text-[10px] text-[#1a1a2e]/20 flex-shrink-0 transition-transform duration-200 select-none">&#9662;</span>
                )}

                {/* Type badge */}
                <span class={`inline-block font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.15em] uppercase px-2 py-0.5 rounded-sm flex-shrink-0 hidden sm:inline-block ${colors.bg} ${colors.text}`}>
                  {typeLabels[item.type]}
                </span>


              </div>
            </div>

            {/* Expandable details panel */}
            {expandable && (
              <div class="schedule-details hidden border-b border-[#1a1a2e]/6 bg-[#1a1a2e]/[0.02]">
                <div class="pl-[19px] pr-4 py-3 space-y-2">
                  {item.abstract && (
                    <p class="font-[family-name:var(--font-source-serif)] text-[13px] text-[#1a1a2e]/50 leading-relaxed">
                      {item.abstract}
                    </p>
                  )}
                  {(item.slides !== undefined || item.recording !== undefined) && (
                    <div class="flex gap-3">
                      {item.slides !== undefined && (
                        <span class={`font-[family-name:var(--font-jetbrains)] text-[9px] tracking-wider uppercase ${item.slides ? 'text-[#1e3a5f] hover:text-[#c0533d] cursor-pointer transition-colors' : 'text-[#1a1a2e]/18'}`}>
                          {item.slides ? <a href={item.slides}>slides</a> : 'slides — coming soon'}
                        </span>
                      )}
                      {item.recording !== undefined && (
                        <span class={`font-[family-name:var(--font-jetbrains)] text-[9px] tracking-wider uppercase ${item.recording ? 'text-[#1e3a5f] hover:text-[#c0533d] cursor-pointer transition-colors' : 'text-[#1a1a2e]/18'}`}>
                          {item.recording ? <a href={item.recording}>recording</a> : 'recording — coming soon'}
                        </span>
                      )}
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>

  {/* Afternoon block */}
  <div class="reveal reveal-delay-2">
    <div class="flex items-center gap-4 mb-5">
      <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.25em] uppercase text-[#1e3a5f]/50 whitespace-nowrap">Afternoon</p>
      <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
    </div>

    <div class="space-y-0">
      {afternoon.map((item, i) => {
        const colors = typeColors[item.type] || typeColors.break;
        const expandable = hasDetails(item);
        return (
          <div class="schedule-row" data-expandable={expandable ? "true" : undefined}>
            <div class={`flex items-stretch border-b border-[#1a1a2e]/6 transition-colors duration-200 hover:bg-[#1e3a5f]/[0.025] ${expandable ? 'cursor-pointer' : ''} ${i % 2 === 0 ? 'bg-[#1a1a2e]/[0.012]' : ''}`}>
              {/* Colored vertical bar */}
              <div class={`w-[3px] flex-shrink-0 rounded-full my-2 ${colors.bar} ${item.type === 'break' ? 'opacity-40' : 'opacity-80'}`}></div>

              <div class="flex-1 flex items-baseline py-3.5 pl-4 pr-2 gap-4 min-w-0">
                {/* Time */}
                <span class={`font-[family-name:var(--font-jetbrains)] text-[13px] tabular-nums flex-shrink-0 w-12 ${item.type === 'break' ? 'text-[#1a1a2e]/30' : 'text-[#1a1a2e]/45'}`}>
                  {item.time}
                </span>

                {/* Title */}
                <span class={`font-[family-name:var(--font-source-serif)] text-[15px] flex-1 min-w-0 ${item.type === 'break' ? 'text-[#1a1a2e]/35 italic' : 'text-[#1a1a2e]'}`}>
                  {item.title}
                </span>

                {/* Expand chevron */}
                {expandable && (
                  <span class="schedule-chevron font-[family-name:var(--font-jetbrains)] text-[10px] text-[#1a1a2e]/20 flex-shrink-0 transition-transform duration-200 select-none">&#9662;</span>
                )}

                {/* Type badge */}
                <span class={`inline-block font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.15em] uppercase px-2 py-0.5 rounded-sm flex-shrink-0 hidden sm:inline-block ${colors.bg} ${colors.text}`}>
                  {typeLabels[item.type]}
                </span>
              </div>
            </div>

            {/* Expandable details panel */}
            {expandable && (
              <div class="schedule-details hidden border-b border-[#1a1a2e]/6 bg-[#1a1a2e]/[0.02]">
                <div class="pl-[19px] pr-4 py-3 space-y-2">
                  {item.abstract && (
                    <p class="font-[family-name:var(--font-source-serif)] text-[13px] text-[#1a1a2e]/50 leading-relaxed">
                      {item.abstract}
                    </p>
                  )}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Expandable schedule rows
  document.querySelectorAll('.schedule-row[data-expandable]').forEach((row) => {
    const trigger = row.querySelector(':scope > div:first-child')!;
    const details = row.querySelector('.schedule-details')!;
    const chevron = row.querySelector('.schedule-chevron');

    trigger.addEventListener('click', () => {
      const open = details.classList.toggle('hidden');
      if (chevron) {
        chevron.classList.toggle('rotate-180', !open);
      }
    });
  });

  // Calendar dropdown
  const calBtn = document.getElementById('cal-btn')!;
  const calDropdown = document.getElementById('cal-dropdown')!;
  const calChevron = document.getElementById('cal-chevron');
  const calCopyBtn = document.getElementById('cal-copy-btn')!;
  const calCopyLabel = document.getElementById('cal-copy-label')!;

  calBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const wasHidden = calDropdown.classList.toggle('hidden');
    calBtn.setAttribute('aria-expanded', String(!wasHidden));
    calChevron?.classList.toggle('rotate-180', !wasHidden);
  });

  document.addEventListener('click', () => {
    calDropdown.classList.add('hidden');
    calBtn.setAttribute('aria-expanded', 'false');
    calChevron?.classList.remove('rotate-180');
  });

  calDropdown.addEventListener('click', (e) => e.stopPropagation());

  calCopyBtn.addEventListener('click', async () => {
    const subscribeUrl = `webcal://${window.location.host}/calendar.ics`;
    try {
      await navigator.clipboard.writeText(subscribeUrl);
      calCopyLabel.textContent = 'Copied!';
      setTimeout(() => { calCopyLabel.textContent = 'Copy subscribe link'; }, 2000);
    } catch {
      calCopyLabel.textContent = subscribeUrl;
      setTimeout(() => { calCopyLabel.textContent = 'Copy subscribe link'; }, 4000);
    }
  });
</script>
