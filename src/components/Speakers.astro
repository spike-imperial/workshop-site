---
import workshop from "../data/workshop.json";

const speakers = (workshop.speakers || []).filter((s: any) => s.visible !== false);

function slugify(name: string): string {
  return "speaker-" + name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
}

// Build lookup from speaker name → schedule entry (for talk title + abstract)
const speakerTalks = new Map(
  workshop.schedule
    .filter((item) => item.speaker && item.speaker !== "TBC")
    .map((item) => [item.speaker, { title: item.title, abstract: item.abstract ?? null }])
);
---

<section id="speakers" class="px-6 py-12 max-w-3xl mx-auto">
  <!-- Section divider -->
  <div class="reveal flex items-center gap-4 mb-10">
    <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
    <div class="w-1.5 h-1.5 rotate-45 border border-[#c0533d]/40"></div>
    <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
  </div>

  <div class="reveal mb-8">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#c0533d] mb-3">Presenters</p>
    <h2 class="font-[family-name:var(--font-fraunces)] text-3xl md:text-4xl text-[#1a1a2e] font-light">Speakers</h2>
  </div>

  {/* Speaker list — hover dims siblings */}
  <div class="speaker-list space-y-0">
    {speakers.map((s, i) => {
      const talk = speakerTalks.get(s.name);
      return (
        <div
          id={slugify(s.name)}
          class={`speaker-card reveal reveal-delay-${(i % 4) + 1} group flex items-center gap-5 px-4 py-3 -mx-4 rounded-md transition-all duration-300 border border-transparent hover:border-[#1a1a2e]/[0.06] hover:bg-white/60 hover:shadow-[0_1px_4px_rgba(0,0,0,0.04)] scroll-mt-24`}
        >
          {/* Profile photo */}
          <div class="flex-shrink-0">
            {s.photo ? (
              <img
                src={s.photo}
                alt={s.name}
                class="w-14 h-14 rounded-full object-cover object-top grayscale-[30%] group-hover:grayscale-0 transition-all duration-500 ring-2 ring-[#1a1a2e]/[0.06] group-hover:ring-[#c0533d]/30"
              />
            ) : (
              <div class="w-14 h-14 rounded-full bg-[#1e3a5f]/10 ring-2 ring-[#1a1a2e]/[0.06] group-hover:ring-[#c0533d]/30 flex items-center justify-center transition-all duration-500">
                <span class="font-[family-name:var(--font-fraunces)] text-lg text-[#1e3a5f]/60 group-hover:text-[#1e3a5f] transition-colors duration-500 select-none">
                  {s.name.split(' ').map((n: string) => n[0]).join('')}
                </span>
              </div>
            )}
          </div>

          {/* Info */}
          <div class="min-w-0 flex-1">
            <div class="flex items-baseline gap-3">
              {/* Name */}
              <h3 class="font-[family-name:var(--font-fraunces)] text-[15px] text-[#1a1a2e] font-normal leading-snug">
                {s.url ? (
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-[#c0533d]/30 underline-offset-2 hover:decoration-[#c0533d] transition-colors duration-200"
                  >
                    {s.name}
                  </a>
                ) : (
                  s.name
                )}
              </h3>
              {/* Role & Affiliation */}
              <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.12em] uppercase text-[#1a1a2e]/35 hidden sm:block">
                {s.role}{s.affiliation && ` · ${s.affiliation}`}
              </p>
            </div>

            {/* Talk title — always visible if assigned */}
            {(s.talk || talk?.title) && (
              <p class="font-[family-name:var(--font-source-serif)] text-[13px] text-[#1a1a2e]/45 italic mt-0.5">
                {s.talk || talk?.title}
              </p>
            )}

            {/* Abstract — revealed on hover */}
            {talk?.abstract && (
              <p class="speaker-abstract font-[family-name:var(--font-source-serif)] text-[12px] text-[#1a1a2e]/40 leading-relaxed mt-1.5 max-h-0 overflow-hidden opacity-0 group-hover:max-h-40 group-hover:opacity-100 transition-all duration-300">
                <span class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.12em] uppercase text-[#1a1a2e]/30 mr-1.5">Abstract:</span>{talk.abstract}
              </p>
            )}
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .speaker-list:hover .speaker-card:not(:hover) {
    opacity: 0.5;
  }
</style>
