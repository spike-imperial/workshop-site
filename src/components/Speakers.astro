---
import workshop from "../data/workshop.json";

const speakers = workshop.speakers || [];

// Count TBC speakers from schedule that aren't in the speakers list
const scheduleSpeakers = workshop.schedule
  .filter((item) => item.speaker && item.speaker !== "TBC")
  .map((item) => item.speaker);
const tbc = workshop.schedule.filter((item) => item.speaker === "TBC").length;
---

<section id="speakers" class="px-6 py-24 max-w-3xl mx-auto">
  <!-- Section divider -->
  <div class="reveal flex items-center gap-4 mb-14">
    <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
    <div class="w-1.5 h-1.5 rotate-45 border border-[#c0533d]/40"></div>
    <div class="h-px flex-1 bg-[#1a1a2e]/8"></div>
  </div>

  <div class="reveal mb-12">
    <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.3em] uppercase text-[#c0533d] mb-3">Presenters</p>
    <h2 class="font-[family-name:var(--font-fraunces)] text-3xl md:text-4xl text-[#1a1a2e] font-light">Speakers</h2>
  </div>

  {/* Speaker grid */}
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-6 gap-y-10">
    {speakers.map((s, i) => (
      <div class={`reveal reveal-delay-${(i % 4) + 1} group text-center`}>
        {/* Profile photo */}
        <div class="relative mx-auto w-24 h-24 mb-4">
          <div class="absolute inset-0 rounded-full bg-[#1a1a2e]/[0.04]"></div>
          <img
            src={s.photo}
            alt={s.name}
            class="relative w-24 h-24 rounded-full object-cover object-top grayscale-[30%] group-hover:grayscale-0 transition-all duration-500 ring-2 ring-[#1a1a2e]/[0.06] group-hover:ring-[#c0533d]/30"
          />
        </div>
        {/* Name */}
        <h3 class="font-[family-name:var(--font-fraunces)] text-[15px] text-[#1a1a2e] font-normal leading-snug">
          {s.name}
        </h3>
        {/* Role */}
        <p class="font-[family-name:var(--font-jetbrains)] text-[9px] tracking-[0.12em] uppercase text-[#1a1a2e]/35 mt-1">
          {s.role}
        </p>
      </div>
    ))}
  </div>

  {/* TBC notice */}
  {tbc > 0 && (
    <div class="reveal reveal-delay-3 mt-12 py-6 border border-dashed border-[#1a1a2e]/10 text-center">
      <p class="font-[family-name:var(--font-source-serif)] text-sm text-[#1a1a2e]/30 italic">
        +{tbc} additional speakers to be confirmed
      </p>
    </div>
  )}
</section>
